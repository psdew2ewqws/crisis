# Copy to backend/.env and fill in your voc360 credentials. NEVER commit the real .env.
VOC_DSN=host=YOUR_HOST port=5432 dbname=voc360 user=YOUR_USER password=YOUR_PASSWORD sslmode=require connect_timeout=15

# LLM transport — Ollama daemon (local models, and cloud `:cloud` tags when
# signed in with Ollama Pro).
LLM_BASE_URL=http://localhost:11434

# Chat / reasoning model. Default: Kimi K2.5 via Ollama cloud (needs Ollama Pro
# + `ollama pull kimi-k2.5:cloud`). Swap for any local tag (e.g. gemma4:26B) to
# run fully offline.
LLM_MODEL=kimi-k2.5:cloud
GEMMA_MODEL=kimi-k2.5:cloud
# Thinking model toggle — false = instant mode (answer text only), true = reasoning.
LLM_THINK=false

# Embeddings stay local.
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# Pinecone — primary vector store for crisis lessons (success + failure cases)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=simulation
PINECONE_NAMESPACE=

# josms.net SMS gateway — sends crisis alerts to phones (server-side only).
# AccName/Sender are fixed to your account; AccPass is a SECRET — never commit the real .env.
JOSMS_ACCNAME=your-account-name
JOSMS_ACCPASS=your-account-password
JOSMS_SENDER=your-sender-id
